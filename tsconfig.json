{
  "include": ["*.ts"],
  "exclude": ["node_modules", ".build"],
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "WebWorker", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Classic",
    "target": "ES2020",
    "outDir": ".build",
    "alwaysStrict": true,
    "strictNullChecks": true,
    "removeComments": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "allowJs": true
  }
}
