{
  "include": ["src/*.ts"],
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "noEmit": true,
    "types": []
  }
}
